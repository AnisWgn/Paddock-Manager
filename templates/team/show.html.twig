{% extends 'base.html.twig' %}

{% block title %}{{ team.name }}{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>{{ team.name }}</h1>
    </div>

    <div class="team-show-card"{% if team.backgroundColor %} style="--team-color: {{ team.backgroundColor }}"{% endif %}>
        {% if team.logo %}
            <img src="{{ team.logo }}" alt="{{ team.name }}" class="team-show-logo">
        {% endif %}
        <table class="table">
            <tbody>
                <tr>
                    <th>Pays</th>
                    <td>{{ team.country }}</td>
                </tr>
                <tr>
                    <th>Logo</th>
                    <td>{% if team.logo %}<a href="{{ team.logo }}" target="_blank" rel="noopener">Voir</a>{% else %}—{% endif %}</td>
                </tr>
                <tr>
                    <th>Image voiture</th>
                    <td>{% if team.carImage %}<a href="{{ team.carImage }}" target="_blank" rel="noopener">Voir</a>{% else %}—{% endif %}</td>
                </tr>
                <tr>
                    <th>Couleur de fond</th>
                    <td>{% if team.backgroundColor %}<span class="team-color-swatch" style="background-color: {{ team.backgroundColor }}"></span> {{ team.backgroundColor }}{% else %}—{% endif %}</td>
                </tr>
            </tbody>
        </table>
        {% if team.carImage %}
            <div class="team-show-car">
                <img src="{{ team.carImage }}" alt="{{ team.name }}">
            </div>
        {% endif %}
    </div>

    <div class="page-actions">
        <a href="{{ path('app_team_index') }}" class="btn btn-outline">← Retour</a>
        <a href="{{ path('app_team_edit', {'id': team.id}) }}" class="btn btn-f1">Modifier</a>
        {{ include('team/_delete_form.html.twig') }}
    </div>
{% endblock %}
