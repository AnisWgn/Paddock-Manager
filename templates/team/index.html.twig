{% extends 'base.html.twig' %}

{% block title %}Écuries{% endblock %}

{% block body %}
    <div class="team-page">
        <div class="page-header">
            <h1>Écuries</h1>
        </div>

        <div class="team-grid">
            {% for team in teams %}
                <div class="team-card-wrapper">
                    <a href="{{ path('app_team_show', {'id': team.id}) }}" class="team-card">
                        <div class="team-card-header">
                            {% if team.logo %}
                                <img src="{{ team.logo }}" alt="{{ team.name }}" class="team-card-logo">
                            {% endif %}
                            <span class="team-card-name">{{ team.name }}</span>
                        </div>
                        <div class="team-card-image">
                            {% if team.carImage %}
                                <img src="{{ team.carImage }}" alt="{{ team.name }}">
                            {% else %}
                                <div class="team-card-placeholder"></div>
                            {% endif %}
                        </div>
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="team-card-admin-actions" onclick="event.stopPropagation();">
                            <a href="{{ path('app_team_edit', {'id': team.id}) }}" class="btn btn-sm btn-outline">Modifier</a>
                            {{ include('team/_delete_form.html.twig', {compact: true}) }}
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <p class="standings-empty">Aucune écurie pour le moment.</p>
            {% endfor %}
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="page-actions">
                <a href="{{ path('app_team_new') }}" class="btn btn-f1">+ Nouvelle écurie</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
