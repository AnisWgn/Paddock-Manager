{% use 'form_div_layout.html.twig' %}

{% block form_row %}
    {% set row_attr = row_attr|merge({class: (row_attr.class|default('') ~ ' form-group')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block form_widget_simple %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' form-control')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block choice_widget_collapsed %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' form-control')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block form_row_render %}
    {% if 'checkbox' in form.vars.block_prefixes %}
        {% set row_attr = row_attr|merge({class: (row_attr.class|default('') ~ ' form-check-row')|trim}) %}
        <div{% with {attr: row_attr} %}{{ block('attributes') }}{% endwith %}>
            {{ form_widget(form, widget_attr|default({})) }}
            {{ form_label(form) }}
            {{ form_errors(form) }}
            {{ form_help(form) }}
        </div>
    {% else %}
        <div{% with {attr: row_attr} %}{{ block('attributes') }}{% endwith %}>
            {{ form_label(form) }}
            {{ form_errors(form) }}
            {{ form_widget(form, widget_attr|default({})) }}
            {{ form_help(form) }}
        </div>
    {% endif %}
{% endblock %}

{% block checkbox_widget %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' form-check-input')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block textarea_widget %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' form-control')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block form_errors %}
    {% if errors|length > 0 %}
    <ul class="form-error-message">
        {% for error in errors %}
            <li id="{{ id ~ '_error' ~ loop.index }}">{{ error.message }}</li>
        {% endfor %}
    </ul>
    {% endif %}
{% endblock %}
