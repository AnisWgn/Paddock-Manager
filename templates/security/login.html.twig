<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Connexion - Paddock Manager</title>
        <meta name="turbo-cache-control" content="no-cache">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏎️</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@400;600;700;900&display=swap" rel="stylesheet">
        {% block importmap %}{{ importmap('app') }}{% endblock %}
        <style>
            :root {
                --f1-red: #e10600;
                --f1-red-dark: #b80500;
                --f1-black: #15151e;
                --f1-dark: #1e1e2a;
                --f1-gray: #38383f;
                --f1-white: #ffffff;
                --f1-carbon: #2d2d35;
                --border-radius: 6px;
                --font: 'Titillium Web', system-ui, sans-serif;
            }
            * { box-sizing: border-box; margin: 0; padding: 0; }
            body {
                font-family: var(--font);
                background: var(--f1-black);
                color: var(--f1-white);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem;
            }
            .login-box {
                width: 100%;
                max-width: 400px;
                background: var(--f1-dark);
                border: 1px solid var(--f1-gray);
                border-radius: var(--border-radius);
                padding: 2.5rem;
            }
            .login-box h1 {
                font-size: 1.5rem;
                font-weight: 900;
                text-transform: uppercase;
                margin-bottom: 1.5rem;
                text-align: center;
            }
            .login-box h1 span { color: var(--f1-red); }
            .login-form .form-group {
                margin-bottom: 1.25rem;
            }
            .login-form label {
                display: block;
                font-size: 0.8rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                color: rgba(255,255,255,0.7);
                margin-bottom: 0.4rem;
            }
            .login-form input {
                width: 100%;
                background: var(--f1-carbon);
                border: 1px solid var(--f1-gray);
                border-radius: var(--border-radius);
                color: var(--f1-white);
                padding: 0.6rem 0.75rem;
                font-family: var(--font);
                font-size: 0.9rem;
            }
            .login-form input:focus {
                outline: none;
                border-color: var(--f1-red);
            }
            .login-form .btn {
                width: 100%;
                margin-top: 0.5rem;
                padding: 0.75rem;
                background: var(--f1-red);
                color: var(--f1-white);
                border: none;
                border-radius: var(--border-radius);
                font-family: var(--font);
                font-size: 0.9rem;
                font-weight: 700;
                text-transform: uppercase;
                cursor: pointer;
                transition: background 0.15s;
            }
            .login-form .btn:hover {
                background: var(--f1-red-dark);
            }
            .login-error {
                background: rgba(225, 6, 0, 0.2);
                border: 1px solid var(--f1-red);
                color: var(--f1-red);
                padding: 0.75rem;
                border-radius: var(--border-radius);
                font-size: 0.9rem;
                margin-bottom: 1rem;
            }
        </style>
    </head>
    <body data-turbo="false">
        <div class="login-box">
            <h1>Paddock <span>Manager</span></h1>

            {% if error %}
                <div class="login-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}" class="login-form">
                <div class="form-group">
                    <label for="inputEmail">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" autocomplete="email" required autofocus>
                </div>

                <div class="form-group">
                    <label for="inputPassword">Mot de passe</label>
                    <input type="password" name="_password" id="inputPassword" autocomplete="current-password" required>
                </div>

                <button type="submit" class="btn">Se connecter</button>
            </form>
        </div>
    </body>
</html>
