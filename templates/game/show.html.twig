{% extends 'base.html.twig' %}

{% block title %}{{ game.title }}{% endblock %}

{% block body %}
    {% set flagCodes = {
        'British': 'gb', 'Britannique': 'gb', 'UK': 'gb', 'United Kingdom': 'gb',
        'French': 'fr', 'France': 'fr', 'Français': 'fr',
        'Dutch': 'nl', 'Netherlands': 'nl', 'Néerlandais': 'nl',
        'German': 'de', 'Germany': 'de', 'Allemand': 'de',
        'Spain': 'es', 'Spanish': 'es', 'Espagnol': 'es',
        'Italian': 'it', 'Italy': 'it', 'Italien': 'it',
        'Australian': 'au', 'Australien': 'au',
        'Canadian': 'ca', 'Canadien': 'ca',
        'American': 'us', 'Américain': 'us', 'USA': 'us',
        'Brazilian': 'br', 'Brésilien': 'br', 'Brazil': 'br',
        'Monegasque': 'mc', 'Monaco': 'mc',
        'Mexican': 'mx', 'Mexicain': 'mx', 'Mexico': 'mx',
        'Thai': 'th', 'Thailand': 'th',
        'Japanese': 'jp', 'Japonais': 'jp', 'Japan': 'jp',
        'China': 'cn', 'Chinese': 'cn', 'Chinois': 'cn',
        'Danish': 'dk', 'Danois': 'dk', 'Denmark': 'dk',
        'Finnish': 'fi', 'Finlandais': 'fi', 'Finland': 'fi',
        'New Zealander': 'nz', 'Néo-Zélandais': 'nz', 'New Zealand': 'nz',
        'Austrian': 'at', 'Autrichien': 'at', 'Austria': 'at',
        'Belgian': 'be', 'Belge': 'be', 'Belgium': 'be',
        'Swiss': 'ch', 'Suisse': 'ch', 'Switzerland': 'ch'
    } %}
    <div class="min-h-screen text-gray-200 p-6 md:p-10 font-sans-tech">
        <div class="max-w-7xl mx-auto space-y-12">
            <div class="flex justify-between items-center">
                <a href="{{ path('app_game_index') }}" class="text-gray-400 hover:text-white font-bold uppercase tracking-wider transition">← Retour</a>
            </div>

            {# SECTION 1 : Informations du Jeu - Image | Titre+Plateformes | Détails #}
            <section class="grid grid-cols-1 md:grid-cols-[14rem_minmax(0,380px)_1fr] gap-10 items-start">
                {# Colonne 1 : Image #}
                <div class="flex flex-col items-center md:items-start">
                    <div class="w-48 md:w-56 h-80 rounded-2xl flex flex-col items-center justify-center overflow-hidden border-2 border-gray-700 shadow-xl bg-gray-800">
                        {% if game.image %}
                            <img src="{{ game.image }}" alt="{{ game.title }}" class="w-full h-full object-cover">
                        {% else %}
                            <svg class="w-24 h-24 text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>
                            </svg>
                            <span class="text-gray-500 font-bold text-xl uppercase tracking-wider">JEU COVER placeholder</span>
                        {% endif %}
                    </div>
                </div>

                {# Colonne 2 : Titre, Saison, Plateformes (entre image et détails) #}
                <div class="space-y-6 flex flex-col items-start text-left">
                    <div class="space-y-1">
                        <h1 class="text-5xl md:text-6xl font-f1-title text-red-600 font-extrabold italic uppercase tracking-tighter leading-tight">
                            {{ game.title|default('GAME SHOW') }}
                        </h1>
                        <p class="text-2xl font-semibold text-gray-400">SAISON {{ game.year|default(2024) }}</p>
                    </div>
                    <div class="w-full space-y-4">
                        <h2 class="text-xl font-bold text-white uppercase tracking-wider">PLATEFORMES</h2>
                        <div class="flex flex-wrap gap-3 justify-start">
                            {% for platform in game.platforms %}
                                {% set platformColor = platform.color|default('#64748b') %}
                                {% set platformLogo = platform.logo|default('') %}
                                {% set platformName = platform.name|default('') %}
                                <span class="px-5 py-2.5 rounded-2xl text-sm font-bold shadow-md flex items-center gap-2"
                                      style="background-color: {{ platformColor }}; color: #FFFFFF;">
                                    {% if platform.logo %}
                                        <i class="fa-brands fa-{{ platformLogo }}"></i>
                                    {% endif %}
                                    {{ platformName }}
                                </span>
                            {% else %}
                                <span class="text-gray-600 font-semibold">Aucune plateforme définie.</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# Colonne 3 : Détails du jeu #}
                <div class="space-y-6 flex flex-col items-start text-left">
                    <h2 class="text-xl font-bold text-white uppercase tracking-wider">DÉTAILS DU JEU</h2>
                    <div class="space-y-4 w-full">
                        {% if game.editeur %}
                            <p class="text-lg"><span class="font-bold text-gray-300">Éditeur :</span> {{ game.editeur }}</p>
                        {% endif %}
                        <p class="text-lg"><span class="font-bold text-gray-300">Date de sortie :</span> {{ game.dateDeSortie ?? game.year }}</p>
                        <div class="p-6 bg-gray-900 rounded-2xl border-2 border-gray-800 shadow-inner space-y-2">
                            <p class="text-lg font-bold text-gray-300">DESCRIPTION :</p>
                            <p class="text-gray-400 leading-relaxed text-base">
                                {{ game.description|default("Le jeu officiel du Championnat du Monde de Formule 1. Pilotez les voitures officielles et affrontez les pilotes et écuries sur les circuits du calendrier.")|nl2br }}
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            {# SECTION 2 : Tableau Classement des Pilotes #}
            <section class="space-y-8">
                <h2 class="text-3xl font-f1-title font-extrabold italic text-white uppercase tracking-tight">
                    CLASSEMENT DES PILOTES (RATINGS - {{ game.title }})
                </h2>

                <div class="bg-gray-900 rounded-2xl border-2 border-gray-800 shadow-xl overflow-x-auto">
                    <table class="w-full text-left text-sm font-sans-tech min-w-[900px]">
                        <thead class="bg-gray-800 border-b-2 border-gray-700">
                            <tr class="text-gray-400 font-bold uppercase tracking-wider">
                                <th class="px-4 py-2 w-16">Pos</th>
                                <th class="px-4 py-2">Pilote</th>
                                <th class="px-4 py-2">Écurie</th>
                                <th class="px-4 py-2 w-24">Global</th>
                                <th class="px-4 py-2">Rythme</th>
                                <th class="px-4 py-2">Expérience</th>
                                <th class="px-4 py-2">Combat</th>
                                <th class="px-4 py-2">Conscience</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-800">
                            {% for rating in driver_ratings|default([]) %}
                                <tr class="hover:bg-gray-800 transition-colors">
                                    <td class="px-4 py-2 font-f1-numeric font-black italic text-3xl text-gray-500">
                                        {{ loop.index }}
                                    </td>
                                    <td class="px-4 py-2">
                                        <div class="flex items-center gap-3">
                                            {% if rating.driver and rating.driver.photo %}
                                                <div class="w-16 h-16 overflow-hidden shrink-0">
                                                    <img src="{{ rating.driver.photo }}" alt="" class="w-full h-full object-cover object-[50%_0%] scale-150 origin-top">
                                                </div>
                                            {% else %}
                                                <div class="w-16 h-16 bg-gray-700 flex items-center justify-center font-mono text-xs text-gray-500 uppercase">
                                                    {% if rating.driver %}
                                                        {{ (rating.driver.firstName ~ ' ' ~ rating.driver.lastName)|slice(0, 3) }}
                                                    {% else %}
                                                        —
                                                    {% endif %}
                                                </div>
                                            {% endif %}
                                            <span class="font-bold text-white text-base">
                                                {% if rating.driver %}
                                                    {{ rating.driver.firstName }} {{ rating.driver.lastName }}
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-2">
                                        <div class="flex items-center gap-3">
                                            {% if rating.driver and rating.driver.team %}
                                                {% if rating.driver.team.logo and (rating.driver.team.logo starts with 'http' or rating.driver.team.logo starts with '/') %}
                                                    <img src="{{ rating.driver.team.logo }}" alt="" class="w-8 h-8 object-contain rounded-md">
                                                {% else %}
                                                    <div class="w-8 h-8 rounded-md bg-gray-700 border border-gray-600 flex items-center justify-center font-mono text-xs text-gray-500 uppercase">
                                                        {{ rating.driver.team.name|slice(0, 3) }}
                                                    </div>
                                                {% endif %}
                                                <span class="text-gray-300">{{ rating.driver.team.name }}</span>
                                            {% else %}
                                                <span class="text-gray-500">—</span>
                                            {% endif %}
                                        </div>
                                    </td>
                                    <td class="px-4 py-2 font-f1-numeric font-black text-4xl text-red-600">
                                        {{ rating.overall ?? '—' }}
                                    </td>
                                    {% for stat in [rating.pace ?? 0, rating.experience ?? 0, rating.racecraft ?? 0, rating.awareness ?? 0] %}
                                        <td class="px-4 py-2">
                                            <div class="flex flex-col items-center gap-1.5">
                                                <span class="font-mono text-2xl font-bold text-gray-300">{{ stat }}</span>
                                                <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden min-w-[80px]">
                                                    <div class="h-full bg-cyan-400 rounded-full transition-all" style="width: {{ stat }}%;"></div>
                                                </div>
                                            </div>
                                        </td>
                                    {% endfor %}
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="8" class="px-4 py-8 text-center text-gray-500 italic">
                                        Aucun pilote dans le classement pour ce jeu.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>

            {# SECTION 3 : Boutons d'Administration #}
            <section class="flex justify-between items-center pt-6 border-t border-gray-800">
                <a href="{{ path('app_game_index') }}" class="text-gray-400 hover:text-white font-bold uppercase tracking-wider transition">← Retour</a>
                {% if is_granted('ROLE_ADMIN') %}
                    <div class="flex gap-4">
                        <a href="{{ path('app_game_edit', {'id': game.id}) }}" class="px-6 py-3 bg-gray-800 text-gray-300 rounded-full font-bold uppercase tracking-wider hover:bg-gray-700 transition">Modifier</a>
                        {{ include('game/_delete_form.html.twig') }}
                    </div>
                {% endif %}
            </section>
        </div>
    </div>
{% endblock %}
