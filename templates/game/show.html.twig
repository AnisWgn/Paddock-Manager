{% extends 'base.html.twig' %}

{% block title %}Game{% endblock %}

{% block body %}
    <h1>{{ game.title }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ game.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ game.title }}</td>
            </tr>
            <tr>
                <th>Year</th>
                <td>{{ game.year }}</td>
            </tr>
            <tr>
                <th>Platform</th>
                <td>{{ game.platform }}</td>
            </tr>
        </tbody>
    </table>

    <div class="page-actions">
        <a href="{{ path('app_game_index') }}" class="btn btn-outline">← Retour</a>
        <a href="{{ path('app_game_edit', {'id': game.id}) }}" class="btn btn-f1">Modifier</a>
        {{ include('game/_delete_form.html.twig') }}
    </div>
{% endblock %}
