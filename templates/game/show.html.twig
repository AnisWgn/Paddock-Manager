{% extends 'base.html.twig' %}

{% block title %}{{ game.title }}{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>{{ game.title }}</h1>
    </div>

    <div class="show-card">
        <dl class="show-dl">
            <dt>Année</dt>
            <dd>{{ game.year }}</dd>
            <dt>Plateforme</dt>
            <dd>{{ game.platform }}</dd>
        </dl>
        {% if game.description %}
            <div class="show-description">
                <h3 class="section-title">Description</h3>
                {{ game.description|nl2br }}
            </div>
        {% endif %}
    </div>

    <div class="page-actions">
        <a href="{{ path('app_game_index') }}" class="btn btn-outline">← Retour</a>
        <a href="{{ path('app_game_edit', {'id': game.id}) }}" class="btn btn-f1">Modifier</a>
        {{ include('game/_delete_form.html.twig') }}
    </div>
{% endblock %}
