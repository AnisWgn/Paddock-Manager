{% extends 'base.html.twig' %}

{% block title %}Grands Prix{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Grands Prix</h1>
    </div>

    <div class="table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Titre</th>
                    <th>Année</th>
                    <th>Plateforme</th>
                    <th class="table-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for game in games %}
                <tr>
                    <td>{{ game.id }}</td>
                    <td><a href="{{ path('app_game_show', {'id': game.id}) }}" class="table-link">{{ game.title }}</a></td>
                    <td>{{ game.year }}</td>
                    <td>
                        {% if game.platforms|length > 0 %}
                            {% for plateform in game.platforms %}
                                {% if loop.index < 4%}
                                    {{ plateform.name }}{% if loop.index < 3 %}, {% endif %}
                                {% else %}
                                    {% if loop.last %}...{% endif %}
                                {% endif %}
                            {% endfor %}
                        {% else %}
                            Aucune plateforme
                        {% endif %}
                    </td>
                    <td class="table-actions">
                        <a href="{{ path('app_game_show', {'id': game.id}) }}" class="btn btn-outline btn-sm">Voir</a>
                        <a href="{{ path('app_game_edit', {'id': game.id}) }}" class="btn btn-f1 btn-sm">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="table-empty">Aucun Grand Prix pour le moment.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="page-actions">
        <a href="{{ path('app_game_new') }}" class="btn btn-f1">+ Nouveau Grand Prix</a>
    </div>
{% endblock %}
