{% extends 'base.html.twig' %}

{% block title %}Grands Prix{% endblock %}

{% block body %}
    <div class="game-page">
        <div class="page-header">
            <h1>Grands Prix</h1>
        </div>

        <div class="game-grid">
            {% for game in games %}
                <div class="game-card-wrapper">
                    <a href="{{ path('app_game_show', {'id': game.id}) }}" class="game-card">
                        <div class="game-card-cover">
                            {% if game.image %}
                                <img src="{{ game.image }}" alt="{{ game.title }}" class="game-card-image">
                            {% else %}
                                <div class="game-card-placeholder"></div>
                            {% endif %}
                        </div>
                        <div class="game-card-info">
                            <h3 class="game-card-title">{{ game.title }}</h3>
                        </div>
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="game-card-admin-actions" onclick="event.stopPropagation();">
                            <a href="{{ path('app_game_edit', {'id': game.id}) }}" class="btn btn-sm btn-outline">Modifier</a>
                            {{ include('game/_delete_form.html.twig', {compact: true}) }}
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <p class="standings-empty">Aucun Grand Prix pour le moment.</p>
            {% endfor %}
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="page-actions">
                <a href="{{ path('app_game_new') }}" class="btn btn-f1">+ Nouveau Grand Prix</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
