<form method="post" action="{{ path('app_driver_delete', {'id': driver.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce pilote ?');" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ driver.id) }}">
    <button type="submit" class="btn btn-sm btn-outline" style="color:#e10600;">Supprimer</button>
</form>
