{% extends 'base.html.twig' %}

{% block title %}Driver{% endblock %}

{% block body %}
    <h1>{{ driver.firstName }} {{ driver.lastName }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ driver.id }}</td>
            </tr>
            <tr>
                <th>FirstName</th>
                <td>{{ driver.firstName }}</td>
            </tr>
            <tr>
                <th>LastName</th>
                <td>{{ driver.lastName }}</td>
            </tr>
            <tr>
                <th>Nationality</th>
                <td>{{ driver.nationality }}</td>
            </tr>
            <tr>
                <th>BirthDate</th>
                <td>{{ driver.birthDate ? driver.birthDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Number</th>
                <td>{{ driver.number }}</td>
            </tr>
            <tr>
                <th>Code</th>
                <td>{{ driver.code }}</td>
            </tr>
            <tr>
                <th>Photo</th>
                <td>{{ driver.photo }}</td>
            </tr>
            <tr>
                <th>IsAlive</th>
                <td>{{ driver.isAlive ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>IsRetired</th>
                <td>{{ driver.isRetired ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <div class="page-actions">
        <a href="{{ path('app_driver_index') }}" class="btn btn-outline">← Retour</a>
        <a href="{{ path('app_driver_edit', {'id': driver.id}) }}" class="btn btn-f1">Modifier</a>
        {{ include('driver/_delete_form.html.twig') }}
    </div>
{% endblock %}
