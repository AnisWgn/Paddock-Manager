<form method="post" action="{{ path('app_driver_rating_delete', {'id': driver_rating.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette note ?');" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ driver_rating.id) }}">
    <button class="btn btn-outline" style="color:#e10600;">Supprimer</button>
</form>
