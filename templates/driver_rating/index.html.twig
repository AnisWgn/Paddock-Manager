{% extends 'base.html.twig' %}

{% block title %}Notes pilotes{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Notes pilotes</h1>
    </div>

    <div class="table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Pilote</th>
                    <th>Grand Prix</th>
                    <th>Overall</th>
                    <th>Pace</th>
                    <th>Experience</th>
                    <th>Racecraft</th>
                    <th>Awareness</th>
                    <th class="table-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for driver_rating in driver_ratings %}
                <tr>
                    <td>{{ driver_rating.id }}</td>
                    <td>{{ driver_rating.driver ? driver_rating.driver.firstName ~ ' ' ~ driver_rating.driver.lastName : '-' }}</td>
                    <td>{{ driver_rating.game ? driver_rating.game.title : '-' }}</td>
                    <td>{{ driver_rating.overall }}</td>
                    <td>{{ driver_rating.pace }}</td>
                    <td>{{ driver_rating.experience }}</td>
                    <td>{{ driver_rating.racecraft }}</td>
                    <td>{{ driver_rating.awareness }}</td>
                    <td class="table-actions">
                        <a href="{{ path('app_driver_rating_show', {'id': driver_rating.id}) }}" class="btn btn-outline btn-sm">Voir</a>
                        <a href="{{ path('app_driver_rating_edit', {'id': driver_rating.id}) }}" class="btn btn-f1 btn-sm">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="9" class="table-empty">Aucune note pour le moment.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="page-actions">
        <a href="{{ path('app_driver_rating_new') }}" class="btn btn-f1">+ Nouvelle note</a>
    </div>
{% endblock %}
