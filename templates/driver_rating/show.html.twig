{% extends 'base.html.twig' %}

{% block title %}Note{% if driver_rating.driver %} - {{ driver_rating.driver.firstName }} {{ driver_rating.driver.lastName }}{% endif %}{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Note{% if driver_rating.driver %} — {{ driver_rating.driver.firstName }} {{ driver_rating.driver.lastName }}{% endif %}</h1>
        {% if driver_rating.game %}
            <p class="page-subtitle">{{ driver_rating.game.title }}</p>
        {% endif %}
    </div>

    <div class="show-card">
        <div class="rating-grid">
            <div class="rating-item">
                <span class="rating-label">Overall</span>
                <span class="rating-value">{{ driver_rating.overall }}/100</span>
            </div>
            <div class="rating-item">
                <span class="rating-label">Pace</span>
                <span class="rating-value">{{ driver_rating.pace }}/100</span>
            </div>
            <div class="rating-item">
                <span class="rating-label">Experience</span>
                <span class="rating-value">{{ driver_rating.experience }}/100</span>
            </div>
            <div class="rating-item">
                <span class="rating-label">Racecraft</span>
                <span class="rating-value">{{ driver_rating.racecraft }}/100</span>
            </div>
            <div class="rating-item">
                <span class="rating-label">Awareness</span>
                <span class="rating-value">{{ driver_rating.awareness }}/100</span>
            </div>
        </div>
    </div>

    <div class="page-actions">
        <a href="{{ path('app_driver_rating_index') }}" class="btn btn-outline">← Retour</a>
        <a href="{{ path('app_driver_rating_edit', {'id': driver_rating.id}) }}" class="btn btn-f1">Modifier</a>
        {{ include('driver_rating/_delete_form.html.twig') }}
    </div>
{% endblock %}
