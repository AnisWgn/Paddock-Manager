{% extends 'base.html.twig' %}

{% block title %}DriverRating{% endblock %}

{% block body %}
    <h1>DriverRating</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ driver_rating.id }}</td>
            </tr>
            <tr>
                <th>Overall</th>
                <td>{{ driver_rating.overall }}</td>
            </tr>
            <tr>
                <th>Pace</th>
                <td>{{ driver_rating.pace }}</td>
            </tr>
            <tr>
                <th>Experience</th>
                <td>{{ driver_rating.experience }}</td>
            </tr>
            <tr>
                <th>Racecraft</th>
                <td>{{ driver_rating.racecraft }}</td>
            </tr>
            <tr>
                <th>Awareness</th>
                <td>{{ driver_rating.awareness }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_driver_rating_index') }}">back to list</a>

    <a href="{{ path('app_driver_rating_edit', {'id': driver_rating.id}) }}">edit</a>

    {{ include('driver_rating/_delete_form.html.twig') }}
{% endblock %}
