<form method="post" action="{{ path('app_plateforme_delete', {'id': plateforme.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette plateforme ?');" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plateforme.id) }}">
    <button type="submit" class="btn btn-outline" style="color:#e10600;">Supprimer</button>
</form>
